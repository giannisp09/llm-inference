# Copy to .env and fill in. Loaded by docker-compose and scripts/serve.sh.

# Which config in configs/ to serve (filename without .yaml)
MODEL_CONFIG=qwen3-0.6b

# Server bind
VLLM_HOST=0.0.0.0
VLLM_PORT=8000

# Hugging Face — needed for gated models (Llama, etc.)
HF_TOKEN=
HF_HOME=/root/.cache/huggingface

# API key clients must present (set "unused" / empty to disable auth)
VLLM_API_KEY=unused
